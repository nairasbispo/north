{
  "entities": {
    "Habit": {
      "title": "Habit",
      "description": "A habit tracked by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the habit" },
        "name": { "type": "string", "maxLength": 100 },
        "completed": { "type": "boolean" },
        "duration": { "type": "string", "maxLength": 50 },
        "icon": { "type": "string", "maxLength": 50 }
      },
      "required": ["id", "name", "completed"]
    },
    "ExerciseLog": {
      "title": "ExerciseLog",
      "description": "An exercise session logged by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Bike", "Caminhada", "Corrida", "Musculação"] },
        "duration": { "type": "integer" },
        "intensity": { "type": "string", "enum": ["Leve", "Moderada", "Intensa"] },
        "notes": { "type": "string", "maxLength": 1000 },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      },
      "required": ["id", "type", "duration", "intensity", "date"]
    },
    "LanguageLog": {
      "title": "LanguageLog",
      "description": "A language practice session logged by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "fr"] },
        "hours": { "type": "number" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "skills": { "type": "array" }
      },
      "required": ["id", "language", "hours", "date", "skills"]
    },
    "UserStats": {
      "title": "UserStats",
      "description": "Global fitness and learning tracking metrics",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "streak": { "type": "integer" },
        "waterAmount": { "type": "number" }
      },
      "required": ["userId", "streak", "waterAmount"]
    },
    "RoutineSettings": {
      "title": "RoutineSettings",
      "description": "User preferences for daily routine goals",
      "type": "object",
      "properties": {
        "wakeTime": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
        "sleepTime": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
        "weeklyExerciseGoal": { "type": "integer" },
        "monthlyLanguageGoal": { "type": "integer" },
        "pushNotifications": { "type": "boolean" },
        "darkTheme": { "type": "boolean" }
      },
      "required": ["wakeTime", "sleepTime", "weeklyExerciseGoal", "monthlyLanguageGoal", "pushNotifications", "darkTheme"]
    }
  },
  "firestore": {
    "users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "Habits of a specific user"
    },
    "users/{userId}/exerciseLogs/{logId}": {
      "schema": "ExerciseLog",
      "description": "Exercise session logs of a specific user"
    },
    "users/{userId}/languageLogs/{logId}": {
      "schema": "LanguageLog",
      "description": "Language practice logs of a specific user"
    },
    "users/{userId}/stats/global": {
      "schema": "UserStats",
      "description": "Global stats/metrics for the user"
    },
    "users/{userId}/settings/routine": {
      "schema": "RoutineSettings",
      "description": "Routine goals and settings for the user"
    }
  }
}
